# --------------------------------------------------
# Arquivos do Composer
# --------------------------------------------------
/vendor/
/composer.lock

# --------------------------------------------------
# Configurações sensíveis
# --------------------------------------------------
.env
.env.*
!.env.example
# --------------------------------------------------
# Cache da aplicação
# --------------------------------------------------
/cache/
/tmp/
/storage/cache/
/storage/logs/

# --------------------------------------------------
# Logs e relatórios de erros
# --------------------------------------------------
*.log
*.error_log
*.php_cs.cache

# --------------------------------------------------
# Arquivos de sessões
# --------------------------------------------------
/sessions/

# --------------------------------------------------
# Diretórios de build e deploy
# --------------------------------------------------
/build/
/dist/

# --------------------------------------------------
# Diretórios de upload
# --------------------------------------------------
/uploads/*
!/uploads/.gitkeep

# --------------------------------------------------
# IDEs (VSCode, PHPStorm, etc)
# --------------------------------------------------
# VSCode
.vscode/
*.code-workspace

# PHPStorm / Jetbrains
.idea/
*.iml

# Eclipse
.project
.buildpath
.settings/

# NetBeans
/nbproject/

# --------------------------------------------------
# Arquivos do sistema operacional
# --------------------------------------------------
.DS_Store
Thumbs.db

# --------------------------------------------------
# Docker
# --------------------------------------------------
/docker/*.log
docker-compose.override.yml

# --------------------------------------------------
# Arquivos temporários
# --------------------------------------------------
*.cache
*.tmp
*.swp
*.bak

# --------------------------------------------------
# Arquivos do PHPUnit
# --------------------------------------------------
/coverage/
/phpunit.xml
.phpunit.result.cache

# --------------------------------------------------
# Arquivos gerados automaticamente
# --------------------------------------------------
/node_modules/
npm-debug.log
yarn-error.log

# --------------------------------------------------
# Outras linguagens misturadas
# --------------------------------------------------
/public/*.map
/public/hot
